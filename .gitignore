# Allowlist policy:
#   This repo tracks SOURCE only (code, config templates, docs).
#   Generated runtime state lives in ~/.config/opencode/memory/ and is NEVER committed.
#   Exception: uv.lock is committed for reproducible installs.

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Memory data (generated at runtime in ~/.config/opencode/memory/, never committed)
chroma_db/
vault/
identity.json
redis-facts-dump.json

# Logs
*.log
backup.log

# Internal
.sisyphus/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

